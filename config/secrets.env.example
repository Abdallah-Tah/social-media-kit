# ──────────────────────────────────────────────────────────────────────────
# Social Media Agent — Secrets Template
# Copy this to secrets.env and fill in only what you use:
#   cp config/secrets.env.example config/secrets.env
# NEVER commit secrets.env to git! (It is gitignored.)
# ──────────────────────────────────────────────────────────────────────────

# ── LLM provider (pick the one set in config/agent.yaml) ────────────────────
# Anthropic (Claude)
BWA_ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY=
# OpenAI / OpenRouter / any OpenAI-compatible endpoint
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# NVIDIA NIM (OpenAI-compatible)
NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Ollama runs locally and needs NO key. Optionally override the URL:
# OLLAMA_BASE_URL=http://localhost:11434/v1
# For Ollama CLOUD (ollama.com): set base_url to https://ollama.com/v1 in
# agent.yaml and provide the key here (use base model names, no :cloud suffix):
# OLLAMA_API_KEY=

# ── Web search ──────────────────────────────────────────────────────────────
# The agent tries: Brave → SearXNG → DuckDuckGo → Wikipedia (first hit wins).
# All free options work with NO key; Wikipedia always works out of the box.
BRAVE_API_KEY=                         # optional, best quality (free tier)
# SEARXNG_URL=https://your-searxng-instance.example   # free, no key
# SEARCH_PROVIDER=                     # force one: brave|searxng|duckduckgo|wikipedia

# ── Blog ────────────────────────────────────────────────────────────────────
# Choose your platform: generic | wordpress | ghost
BLOG_PLATFORM=generic
BLOG_API_URL=https://yourblog.com/api/v1
BLOG_API_TOKEN=
# WordPress only: site root as BLOG_API_URL (https://site.com), plus an
# Application Password as BLOG_API_TOKEN and your username here:
# BLOG_API_USER=admin
# Ghost only: BLOG_API_URL=https://site.com and BLOG_API_TOKEN=<Admin API key id:secret>

# ── Facebook Page ───────────────────────────────────────────────────────────
FB_PAGE_ID=
FB_PAGE_TOKEN=
FB_GRAPH_VERSION=v21.0

# ── X (Twitter) ──────────────────────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# ── Slack (use EITHER an incoming webhook OR a bot token) ───────────────────
SLACK_WEBHOOK_URL=
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL=#general

# ── Discord (incoming webhook) ──────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Telegram (Bot API) ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Mastodon ────────────────────────────────────────────────────────────────
MASTODON_BASE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# ── Bluesky (AT Protocol — use an App Password, not your login password) ────
BLUESKY_HANDLE=you.bsky.social
BLUESKY_APP_PASSWORD=
# BLUESKY_PDS=https://bsky.social

# ── Threads (Meta Threads API) ──────────────────────────────────────────────
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ── YouTube Shorts (Google OAuth / YouTube Data API v3) ─────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Reddit (create a "script" app at reddit.com/prefs/apps) ─────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_SUBREDDIT=test
REDDIT_USER_AGENT=social-media-agent by u/yourname

# ── Pinterest (API v5) ──────────────────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# ── Generic webhook (ANY other platform: Zapier, Make, n8n, Buffer, …) ──────
WEBHOOK_URL=
# WEBHOOK_TEXT_KEY=text
# WEBHOOK_AUTH_HEADER=Bearer your_token

# ── Cover image generation (optional — falls back to a free branded card) ───
# FAL.ai (flux-pro) — best quality:
FAL_KEY=
# Or use OpenAI Images with the OPENAI_API_KEY above.
# Force a provider: IMAGE_PROVIDER=fal|openai|card
# IMAGE_PROVIDER=
# FAL_MODEL=fal-ai/flux-pro/v1.1-ultra
# OPENAI_IMAGE_MODEL=gpt-image-1
