# ──────────────────────────────────────────────────────────────────────────
# Social Media Agent — Secrets Template
# Copy this to secrets.env and fill in only what you use:
#   cp config/secrets.env.example config/secrets.env
# NEVER commit secrets.env to git! (It is gitignored.)
# ──────────────────────────────────────────────────────────────────────────

# ── LLM provider (pick the one set in config/agent.yaml) ────────────────────
# Anthropic (Claude)
ANTHROPIC_API_KEY=
# OpenAI / OpenRouter / any OpenAI-compatible endpoint
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Ollama runs locally and needs NO key. Optionally override the URL:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Web search (optional — falls back to DuckDuckGo if unset) ───────────────
BRAVE_API_KEY=

# ── Blog (REST API: Laravel, WordPress, Ghost, custom) ──────────────────────
BLOG_API_URL=https://yourblog.com/api/v1
BLOG_API_TOKEN=

# ── Facebook Page ───────────────────────────────────────────────────────────
FB_PAGE_ID=
FB_PAGE_TOKEN=
FB_GRAPH_VERSION=v21.0

# ── X (Twitter) ──────────────────────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# ── Slack (use EITHER an incoming webhook OR a bot token) ───────────────────
SLACK_WEBHOOK_URL=
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL=#general

# ── Discord (incoming webhook) ──────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Telegram (Bot API) ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Mastodon ────────────────────────────────────────────────────────────────
MASTODON_BASE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# ── Generic webhook (ANY other platform: Zapier, Make, n8n, Buffer, …) ──────
WEBHOOK_URL=
# WEBHOOK_TEXT_KEY=text
# WEBHOOK_AUTH_HEADER=Bearer your_token
